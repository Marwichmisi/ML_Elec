# ML_Elec - Variables d'environnement
# Copiez ce fichier vers .env et remplissez les valeurs

# =============================================================================
# GÉNÉRAL
# =============================================================================
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# =============================================================================
# JWT (JWT_SECRET doit faire au moins 32 caractères)
# =============================================================================
JWT_SECRET=votre-secret-jwt-tres-long-et-securise-pour-la-production
JWT_EXPIRES_IN=24h

# =============================================================================
# DUCKDB (Stockage des données)
# =============================================================================
DUCKDB_DATA_DIR=./data/duckdb
DUCKDB_MEMORY_LIMIT=1.5GB
DUCKDB_THREADS=2

# =============================================================================
# MQTT (Broker de messages)
# =============================================================================
MQTT_BROKER_URL=mqtt://localhost:1883

# =============================================================================
# OPC-UA (Collecte de données industrielles)
# =============================================================================
OPCUA_ENDPOINT=opc.tcp://localhost:4840
